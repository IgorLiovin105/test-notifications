{
	"preset": "laravel",
	"rules": {
		"array_syntax": true,
		"concat_space": {
			"spacing": "one"
		},
		"not_operator_with_successor_space": true,
		"ordered_imports": true,
		"phpdoc_align": true,
		"phpdoc_separation": true,
		"phpdoc_trim": true,
		"single_quote": true,
		"trailing_comma_in_multiline": true
	}
}